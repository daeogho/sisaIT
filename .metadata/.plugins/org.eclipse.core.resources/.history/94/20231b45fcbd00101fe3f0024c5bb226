package J01_basic;

import java.util.Scanner;

public class J04If1 {

	public static void main(String[] args) {
		// 정수를 입력받아 입력받은 값이
		// 1~100사이일때만 입력받은 값에 100을 곱하여 출력하라.
		
		Scanner scan = new Scanner(System.in);
		
		System.out.print("1~100사이의 정수를 입력=");
		int num = scan.nextInt();
		
		// 조건식 : tre or false가 나오는 수식, 논리형 값
		if(num>=1 && num<=100) {// 1~100사이일때 참
			int result = num*100;
			System.out.printf("처리결과=%d", result);
		
		
		System.out.println(num);
		//System.out.println(result); result는 지역변수 if벗어나서는 사용x
		
		
		int a = 500;
			System.out.println(a);
						
		
		//System.out.println(a); 괄호 안에서만 사용가능
		
		
		}
		System.out.println("\n==============The End==============");
	}

}
