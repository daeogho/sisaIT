package j10io;

import java.io.File;

public class FileTest {

	public FileTest() {
		// File : 파일관련된 드라이브, 경로, 파일명에 관한 정보를 처리할 수 있다.
		// 드라이브명
		File f1 = new File("c:/");
		File f2 = new File("c:/study/javaTest");
		File f3 = new File("c:/study/javaTest", "Test.java");
		File f4 = new File("c:/study/javaTest/Test.java");
		File f5 = new File(f2, "Test.java");
		
		// file의 크기
		long length = f3.length();
		System.out.println("length=>" + length + "byte");
		
		// 만들 폴더를 File객체로 생성
		File f6 = new File("c:/study/javaTest/a1/b1");
		f6.mkdirs();
	}

	public static void main(String[] args) {
		new FileTest();

	}

}
