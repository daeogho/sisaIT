package J01_basic;

public class J24For {

	public static void main(String[] args) {
		// 중첩 for문 
		for(int i = 1; i <=7 ; i++) { //줄수
			
			for(int j = 1; j <=6 ; j++) { //칸수
				//System.out.print(" i=" + i + ", j=" + j + "/");
				System.out.print("*");
			}
			// 줄바꿈
			System.out.println();
		}

	}

}
